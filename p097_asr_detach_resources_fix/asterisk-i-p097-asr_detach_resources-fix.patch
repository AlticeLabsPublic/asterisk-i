+/******************************************************************************
+ *        NAME: cleanup_asr_resources()
+ * DESCRIPTION: Helper function to cleanup ASR resources
+ *              
+ *****************************************************************************/
+static void cleanup_asr_resources(ast_vars *chan_vars, int ch_index)
+{
+	if (chan_vars->asr.asr_sock > 2) {
+		if (option_verbose >= 3)
+			ast_verbose(VERBOSE_PREFIX_3 "Stopping ASR and closing socket on ch %03d\n", ch_index);
+
+		if (chan_vars->asr.asr_writetrans) {
+			ast_translator_free_path(chan_vars->asr.asr_writetrans);
+			chan_vars->asr.asr_writetrans = NULL;
+		}
+
+		close(chan_vars->asr.asr_sock);
+		chan_vars->asr.asr_sock = -1;
+	}
+}
